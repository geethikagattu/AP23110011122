# Vehicle Maintenance Scheduler Environment Variables

# API Authentication
# Bearer token for accessing protected depot and vehicle APIs
API_TOKEN=your-bearer-token-here

# API Endpoints (optional - defaults to example URLs)
# DEPOTS_API_URL=https://api.example.com/depots
# VEHICLES_API_URL=https://api.example.com/vehicles

# Output Configuration (optional)
# RESULTS_DIR=./results
# LOG_LEVEL=info